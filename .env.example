# ─────────────────────────────────────────────────────────────────
# PR Plus Backend — Environment Configuration
# Copy to .env and fill in values before running
# ─────────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database (SQLite file path)
DB_PATH=./data/prplus.db

# Cache TTL in seconds
CACHE_TTL_INVITATIONS=86400     # 24 hours — DHA updates monthly
CACHE_TTL_STATES=21600          # 6 hours  — state sites update frequently
CACHE_TTL_NEWS=3600             # 1 hour   — news changes daily
CACHE_TTL_OCCUPATIONS=604800    # 7 days   — occupation lists rarely change

# Scraper config
SCRAPER_TIMEOUT_MS=15000        # 15 second timeout per request
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_DELAY_MS=2000           # polite delay between requests
USER_AGENT=PRPlus-Bot/1.0 (Australian PR research tool; contact@prplus.com.au)

# data.gov.au CKAN API (public, no key required)
DATA_GOV_AU_BASE=https://data.gov.au/api/3/action

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Optional: Anthropic API key for AI-powered features
ANTHROPIC_API_KEY=

# Optional: Proxy for scraping (if needed)
# PROXY_URL=http://user:pass@proxy:port
